{
  "name": "aether",
  "private": true,
  "version": "0.1.58",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "nodemon",
    "start": "vite",
    "build": "tsc && vite build",
    "postbuild": "node scripts/warmWeatherCache.js",
    "preview": "vite preview",
